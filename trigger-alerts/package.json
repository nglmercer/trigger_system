{
  "name": "trigger-alerts",
  "version": "1.0.0",
  "description": "Self-rendering alert components for Trigger System with text, video, and audio support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --minify --sourcemap=external",
    "dev": "bun --watch ./demo.html",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "animejs": "^4.3.6",
    "lit": "^3.1.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "trigger_system": "*"
  },
  "private": true
}